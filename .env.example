# MIDAS environment - copy to .env and fill. NEVER commit .env.

# Local providers
OLLAMA_BASE_URL=http://localhost:11434
LM_STUDIO_BASE_URL=http://localhost:1234/v1
VLLM_BASE_URL=http://localhost:8000/v1

# Cloud providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
AZURE_API_KEY=
AZURE_API_BASE=
VERTEX_PROJECT=
AWS_REGION=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
COHERE_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=
CEREBRAS_API_KEY=
FIREWORKS_API_KEY=
REPLICATE_API_TOKEN=
HUGGINGFACE_API_KEY=

# Custom OpenAI-compatible endpoint
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=

# Default routing
MIDAS_MODEL_CHEAP=ollama/llama3.1
MIDAS_MODEL_SMART=anthropic/claude-sonnet
MIDAS_RUN_MODE=deep

# Channels
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# Cost guardrails in USD
MIDAS_DAILY_SPEND_CAP=2.00
MIDAS_PER_TASK_SPEND_CAP=0.25
MIDAS_MONTHLY_SPEND_CAP=30.00

# Optional integrations
GITHUB_TOKEN=
OBSIDIAN_VAULT_PATH=
BRAVE_SEARCH_API_KEY=
NOTION_TOKEN=
MIDAS_SEARXNG_URL=

# Safety
MIDAS_AUTONOMY=semi-auto
MIDAS_KILL_SWITCH=false
