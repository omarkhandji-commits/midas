# ── MIDAS environment ── copy to .env and fill. NEVER commit .env. ──

# === LLM providers (fill at least one; MIDAS is provider-agnostic) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
TOGETHER_API_KEY=          # for Nous/Hermes and other open models
OLLAMA_BASE_URL=http://localhost:11434   # local, free fallback

# Default routing (see config/providers.example.yml)
MIDAS_MODEL_CHEAP=ollama/llama3.1        # high-volume, low-stakes work
MIDAS_MODEL_SMART=anthropic/claude-sonnet # high-stakes decisions only

# === Channels ===
TELEGRAM_BOT_TOKEN=        # for mobile approve/reject + alerts
TELEGRAM_OWNER_CHAT_ID=    # only this chat can approve actions

# === Cost guardrails (USD) — hard caps, agent auto-halts past these ===
MIDAS_DAILY_SPEND_CAP=2.00
MIDAS_PER_TASK_SPEND_CAP=0.25
MIDAS_MONTHLY_SPEND_CAP=30.00

# === Optional integrations (read-only or draft-only by default) ===
GITHUB_TOKEN=              # gh CLI; repo WRITES still require approval
OBSIDIAN_VAULT_PATH=       # local folder, read-only
BRAVE_SEARCH_API_KEY=      # free tier web search
NOTION_TOKEN=              # optional simple CRM / task board

# === Safety ===
MIDAS_AUTONOMY=semi-auto   # approval-default. opt-in: full-auto-guarded | propose-only
MIDAS_KILL_SWITCH=off      # set to "on" to freeze ALL agent actions
